---
import { Icon } from "astro-icon/components";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div class="comment-btn-wrapper">
    <div id="comment-btn" class="comment-btn hide flex items-center justify-center rounded-full lg:rounded-2xl overflow-hidden transition" onclick="scrollToComment()">
        <button aria-label="Scroll to Comments" class="btn-card h-[3rem] w-[3rem] lg:h-[3.75rem] lg:w-[3.75rem]">
            <Icon name="mingcute:comment-fill" class="mx-auto"></Icon>
        </button>
    </div>
</div>

<style lang="stylus">
.comment-btn-wrapper
    position: absolute
    right: 0
    top: 0
    pointer-events: none
    width: 3rem
    height: 3rem
    @media (min-width: 1024px)
        width: 3.75rem
        height: 3.75rem

.comment-btn
    color: var(--primary)
    font-size: 2.25rem
    font-weight: bold
    border: none
    position: fixed
    opacity: 1
    cursor: pointer
    pointer-events: auto
    z-index: 40
    // Mobile: independent fixed position at bottom-right
    bottom: calc(5.5rem + env(safe-area-inset-bottom, 0px))
    right: 1.5rem
    transform: translateY(0)
    transition: opacity 0.3s ease, transform 0.3s ease
    i
        font-size: 1.75rem
    &.hide
        transform: translateY(1rem) scale(0.9)
        opacity: 0
        pointer-events: none
    &:active
        transform: scale(0.9)
    @media (min-width: 1024px)
        right: auto
        bottom: 14.5rem
        transform: translateX(5rem)
        transition: opacity 0.3s ease, transform 0.3s ease
        &.hide
            transform: translateX(5rem) scale(0.9)
        &:active
            transform: translateX(5rem) scale(0.9)

</style>

<script is:raw is:inline>
function scrollToComment() {
    const giscusContainer = document.getElementById('giscus-container');
    if (giscusContainer) {
        giscusContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
}
</script>

<script is:inline>
// Show/hide logic - similar to BackToTop
function handleScroll() {
    const commentBtn = document.getElementById('comment-btn');
    const giscusContainer = document.getElementById('giscus-container');

    if (!commentBtn) return;

    const hasCommentSection = !!giscusContainer;

    if (hasCommentSection) {
        const rect = giscusContainer.getBoundingClientRect();
        const scrollHeight = 200;
        const isCommentVisible = rect.top < window.innerHeight && rect.bottom > 0;

        if ((window.pageYOffset > scrollHeight) && !isCommentVisible) {
            commentBtn.classList.remove('hide');
        } else {
            commentBtn.classList.add('hide');
        }
    } else {
        commentBtn.classList.add('hide');
    }
}

window.addEventListener('scroll', handleScroll);
window.addEventListener('load', handleScroll);

document.addEventListener('swup:contentReplaced', () => {
    handleScroll();
});
</script>
