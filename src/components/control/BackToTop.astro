---
import { Icon } from "astro-icon/components";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div class="back-to-top-wrapper">
    <div id="back-to-top-btn" class="back-to-top-btn hide flex items-center justify-center rounded-full lg:rounded-2xl overflow-hidden transition" onclick="backToTop()">
        <button aria-label="Back to Top" class="btn-card h-[3rem] w-[3rem] lg:h-[3.75rem] lg:w-[3.75rem]">
            <Icon name="material-symbols:keyboard-arrow-up-rounded" class="mx-auto"></Icon>
        </button>
    </div>
</div>

<style lang="stylus">
.back-to-top-wrapper
    position: absolute
    right: 0
    top: 0
    pointer-events: none
    width: 3rem
    height: 3rem
    @media (min-width: 1024px)
        width: 3.75rem
        height: 3.75rem

.back-to-top-btn
    color: var(--primary)
    font-size: 2.25rem
    font-weight: bold
    border: none
    position: fixed
    opacity: 1
    cursor: pointer
    pointer-events: auto
    z-index: 40
    // Mobile: independent fixed position at bottom-right
    bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px))
    right: 1.5rem
    transform: translateY(0)
    transition: opacity 0.3s ease, transform 0.3s ease
    i
        font-size: 1.75rem
    &.hide
        transform: translateY(1rem) scale(0.9)
        opacity: 0
        pointer-events: none
    &:active
        transform: scale(0.9)
    @media (min-width: 1024px)
        right: auto
        bottom: 10rem
        transform: translateX(5rem)
        transition: opacity 0.3s ease, transform 0.3s ease
        &.hide
            transform: translateX(5rem) scale(0.9)
        &:active
            transform: translateX(5rem) scale(0.9)

</style>

<script is:raw is:inline>
function backToTop() {
    window.scroll({ top: 0, behavior: 'smooth' });
}
</script>
