---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config";
import { getTotalWords, getPostCount } from "../../utils/content-utils";
import WidgetLayout from "./WidgetLayout.astro";

const totalWords = await getTotalWords();
const postCount = await getPostCount();

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout
	name={i18n(I18nKey.siteStats)}
	id="site-stats"
	class={className}
	style={style}
>
	<div class="grid grid-cols-2 gap-3">
		<!-- 文章数 -->
		<div class="text-center p-2 rounded-lg bg-neutral-50/50 dark:bg-neutral-800/30 hover:bg-neutral-100/50 dark:hover:bg-neutral-700/30 transition">
			<div class="text-xs text-neutral-500 mb-1 flex items-center justify-center gap-1">
				<Icon name="material-symbols:article" class="text-base"></Icon>
				<span class="text-xs">{i18n(I18nKey.postCountLabel)}</span>
			</div>
			<div id="site-post-count" class="font-bold text-lg text-neutral-700 dark:text-neutral-300">
				{postCount}
			</div>
		</div>

		<!-- 总字数 -->
		<div class="text-center p-2 rounded-lg bg-neutral-50/50 dark:bg-neutral-800/30 hover:bg-neutral-100/50 dark:hover:bg-neutral-700/30 transition">
			<div class="text-xs text-neutral-500 mb-1 flex items-center justify-center gap-1">
				<Icon name="material-symbols:notes" class="text-base"></Icon>
				<span class="text-xs">{i18n(I18nKey.totalWords)}</span>
			</div>
			<div id="site-total-words" class="font-bold text-lg text-neutral-700 dark:text-neutral-300">
				0
			</div>
		</div>

		<!-- 访问量 -->
		<div class="text-center p-2 rounded-lg bg-neutral-50/50 dark:bg-neutral-800/30 hover:bg-neutral-100/50 dark:hover:bg-neutral-700/30 transition">
			<div class="text-xs text-neutral-500 mb-1 flex items-center justify-center gap-1">
				<Icon name="material-symbols:visibility-outline" class="text-base"></Icon>
				<span class="text-xs">访问量</span>
			</div>
			<div id="site-views" class="font-bold text-lg text-neutral-700 dark:text-neutral-300"
		     data-umami-site data-umami-type="site-pageviews" data-umami-suffix="">--</div>
		</div>

		<!-- 访客数 -->
		<div class="text-center p-2 rounded-lg bg-neutral-50/50 dark:bg-neutral-800/30 hover:bg-neutral-100/50 dark:hover:bg-neutral-700/30 transition">
			<div class="text-xs text-neutral-500 mb-1 flex items-center justify-center gap-1">
				<Icon name="material-symbols:person" class="text-base"></Icon>
				<span class="text-xs">访客数</span>
			</div>
			<div id="site-visitors" class="font-bold text-lg text-neutral-700 dark:text-neutral-300"
		     data-umami-site data-umami-type="site-visitors" data-umami-suffix="">--</div>
		</div>
	</div>
</WidgetLayout>

<script define:vars={{ totalWords, postCount }}>
	// 数字动画函数
	function animateValue(obj, start, end, duration) {
		let startTimestamp = null;
		const step = (timestamp) => {
			if (!startTimestamp) startTimestamp = timestamp;
			const progress = Math.min((timestamp - startTimestamp) / duration, 1);
			obj.innerHTML = Math.floor(progress * (end - start) + start);
			if (progress < 1) {
				window.requestAnimationFrame(step);
			} else {
				obj.innerHTML = end;
			}
		};
		window.requestAnimationFrame(step);
	}

	// 标记是否正在swup跳转
	let isSwupNavigating = false;

	// umami site stats 动画：轮询等待值填充后从0滚动到目标值
	function animateUmamiSiteStats() {
		var targets = [
			{ id: 'site-views', cacheKey: 'umami-site-pageviews' },
			{ id: 'site-visitors', cacheKey: 'umami-site-visitors' }
		];

		targets.forEach(function(target) {
			var el = document.getElementById(target.id);
			if (!el) return;

			// 清除缓存（swup跳转时不清除）
			if (!isSwupNavigating) {
				sessionStorage.removeItem(target.cacheKey);
			}

			var cached = sessionStorage.getItem(target.cacheKey);
			if (cached !== null && isSwupNavigating) {
				// swup跳转时直接显示缓存值
				el.textContent = cached;
				return;
			}

			// 轮询等待 umami 填充值
			var timer = setInterval(function() {
				var raw = el.dataset.rawValue;
				var num = parseInt(raw, 10);
				if (num > 0 && !isNaN(num)) {
					clearInterval(timer);
					if (!isSwupNavigating) {
						// 首次加载：从0动画到目标值
						animateValue(el, 0, num, 1000);
					}
					sessionStorage.setItem(target.cacheKey, String(num));
				}
			}, 80);

			// 安全：15秒后停止轮询
			setTimeout(function() { clearInterval(timer); }, 15000);
		});
	}

	// 动画显示本地统计数据（文章数 & 总字数）
	async function loadSiteStats() {
		const postCountElement = document.getElementById('site-post-count');
		const totalWordsElement = document.getElementById('site-total-words');

		// 使用 sessionStorage 缓存数据
		const postCountCacheKey = 'site-post-count';
		const totalWordsCacheKey = 'site-total-words';

		// 如果不是swup跳转，清除缓存（刷新时需要重新播放动画）
		if (!isSwupNavigating) {
			sessionStorage.removeItem(postCountCacheKey);
			sessionStorage.removeItem(totalWordsCacheKey);
		}

		const cachedPostCount = sessionStorage.getItem(postCountCacheKey);
		const cachedTotalWords = sessionStorage.getItem(totalWordsCacheKey);

		// 如果有缓存（swup跳转），先立即显示缓存值
		if (cachedPostCount !== null && postCountElement) {
			postCountElement.textContent = cachedPostCount;
		}
		if (cachedTotalWords !== null && totalWordsElement) {
			totalWordsElement.textContent = cachedTotalWords;
		}

		// 文章数动画
		if (postCountElement) {
			const startVal = parseInt(postCountElement.textContent) || 0;
			if (startVal > 0) {
				if (cachedPostCount === null) {
					animateValue(postCountElement, 0, startVal, 1000);
				}
			} else {
				postCountElement.textContent = startVal;
			}
			sessionStorage.setItem(postCountCacheKey, startVal);
		}

		// 总字数动画
		if (totalWordsElement) {
			const startVal = parseInt(totalWordsElement.textContent) || 0;
			if (startVal !== totalWords) {
				if (cachedTotalWords === null) {
					animateValue(totalWordsElement, startVal, totalWords, 1000);
				} else if (startVal !== totalWords) {
					totalWordsElement.textContent = totalWords;
				}
			} else {
				totalWordsElement.textContent = totalWords;
			}
			sessionStorage.setItem(totalWordsCacheKey, totalWords);
		}

		// umami site stats 动画
		animateUmamiSiteStats();
	}

	document.addEventListener('DOMContentLoaded', loadSiteStats);
	// 监听swup事件
	document.addEventListener('swup:contentReplaced', () => {
		isSwupNavigating = true;
		loadSiteStats();
		setTimeout(() => { isSwupNavigating = false; }, 100);
	});
</script>
